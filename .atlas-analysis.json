  "keyFeatures": [
    "Header-only C++ library with no runtime allocation",
    "Partial implementation of P2300 (std::execution) proposal",
    "Interrupt-driven async execution via priority and timer schedulers",
    "Zero-exception error handling using error values on dedicated channels",
    "Composable sender factories, adaptors, and consumers with pipe syntax",
    "Cooperative cancellation via stop_source/stop_token/stop_callback",
    "Compile-time debug signaling framework for async tracing",
    "C++20 and C++23 support (GCC 12-14, Clang 14-22)"
  ],
